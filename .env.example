# Local development defaults. Replace the password with your own local Postgres password.
DATABASE_URL=postgresql+asyncpg://postgres:your-local-postgres-password@localhost:5432/cosmetics_db
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
UPLOAD_DIR=uploads
PAYMENT_PROVIDER=bank_qr
PAYMENT_WEBHOOK_SECRET=change-payment-webhook-secret
PAYMENT_EXPIRE_MINUTES=15
ENABLE_MOCK_PAYMENTS=false
GOOGLE_CLIENT_ID=
DATABASE_ECHO=false
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=admin123
CHATBOT_AI_API_KEY=
CHATBOT_AI_BASE_URL=
CHATBOT_AI_MODEL=
CHATBOT_AI_TIMEOUT_SECONDS=30
CHATBOT_HOTLINE=
CHATBOT_SCOPE_FILE=chatbot.md
CHATBOT_MAX_HISTORY_MESSAGES=8
CHATBOT_WORD_LIMIT=100
CHATBOT_STREAM_CHUNK_SIZE=24
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
